MONGO_URI=mongodb://localhost:27017/nutri
JWT_SECRET=change-me-to-a-random-secret
SERVICE_API_KEY=change-me-to-a-random-api-key
USDA_API_KEY=your_usda_api_key_here
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-public-r2-domain.example.com
# CHROME_PATH: path to a Chrome/Chromium binary, used by puppeteer-core for meal-plan PDF
# export (mealplans.service.js). Defaults to a macOS-only path — leave unset locally on
# macOS, but MUST be set in production (Render), since no Chrome binary exists there by
# default. See TODO.md → "Infrastructure / Cross-cutting" for the real fix needed.
CHROME_PATH=
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
PORT=3000
